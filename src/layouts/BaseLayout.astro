---
import '../styles/global.css';

type Props = {
  title?: string;
  description?: string;
};

const {
  title = 'Lucas Marchand — Software / AI Engineer',
  description = 'Portfolio de Lucas Marchand: backend Python, agentic AI, NLP-to-SQL, computer vision temps réel et systèmes robustes.'
} = Astro.props;

const linkedinUrl = 'https://www.linkedin.com/in/lucassmarchand';
const githubUrl = 'https://github.com/LucasMarchnd';
const emailUrl = 'mailto:contact@lucasmarchand.dev';
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://lucasmarchand.dev" />
    <meta name="theme-color" content="#fbfaf5" />
    <link rel="icon" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/">Lucas Marchand</a>
      <nav aria-label="Navigation principale">
        <a href="/#projects">Projets</a>
        <a href="/#about">Profil</a>
        <a href={linkedinUrl} target="_blank" rel="noreferrer">LinkedIn</a>
        <a href={githubUrl} target="_blank" rel="noreferrer">GitHub</a>
        <a class="nav-cta" href={emailUrl}>Contact</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>lucasmarchand.dev · Built with Astro · Disponible à partir de septembre 2026.</p>
    </footer>
  </body>
</html>
