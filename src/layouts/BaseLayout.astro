---
import '../styles/global.css';

type Props = {
  title?: string;
  description?: string;
};

const {
  title = 'Lucas Marchand — Software & AI Engineer',
  description = 'Portfolio de Lucas Marchand: backend, agentic AI, NLP-to-SQL, cloud et systèmes temps réel.'
} = Astro.props;
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/">Lucas Marchand</a>
      <nav aria-label="Navigation principale">
        <a href="/#projects">Projects</a>
        <a href="/#about">About</a>
        <a href="mailto:marchandlucas3@gmail.com">Contact</a>
        <a href="https://github.com/LucasMarchnd" target="_blank" rel="noreferrer">GitHub</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>Built with Astro · Available for a junior Software / AI Engineer role from September 2026.</p>
    </footer>
  </body>
</html>
