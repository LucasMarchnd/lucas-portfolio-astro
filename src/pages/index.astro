---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const featured = projects.filter((project) => project.data.featured);
const otherProjects = projects.filter((project) => !project.data.featured);

const links = {
  linkedin: 'https://www.linkedin.com/in/lucassmarchand',
  github: 'https://github.com/LucasMarchnd',
  email: 'mailto:contact@lucasmarchand.dev',
};

const proofPoints = [
  {
    label: 'Systèmes GenAI',
    value: 'Agents, RAG, NLP-to-SQL, routage, validation et traçabilité.',
  },
  {
    label: 'Backend Python',
    value: 'API, tests, streaming, observabilité et gestion d’erreurs.',
  },
  {
    label: 'Vision / Edge AI',
    value: 'RTSP, NVIDIA Jetson, monitoring, contraintes temps réel et reprise sur erreur.',
  },
];

const labs = [
  {
    status: 'WIP · 2026',
    title: 'Agentic NLP-to-SQL Workflow',
    summary:
      'Prototype public-safe autour de workflows agentiques pour le NLP-to-SQL: routage, génération SQL, dry-run, correction automatique, validation et traçabilité.',
    stack: ['Python', 'Google ADK', 'SQL', 'Agents', 'GenAI'],
    tags: ['agentic-ai', 'nlp-to-sql', 'backend'],
    action: 'Bientôt disponible',
  },
  {
    status: 'Prototype · 2026',
    title: 'ADK v2 Workflow Samples',
    summary:
      'Exemples de workflows graph-based pour expérimenter orchestration, routage, outils et patterns agentiques avec Google ADK.',
    stack: ['Python', 'Google ADK', 'Agents', 'Workflows'],
    tags: ['agentic-ai', 'workflow-design', 'python'],
    action: 'Voir sur GitHub',
    repo: 'https://github.com/LucasMarchnd/adk-v2-workflow-samples',
  },
];
---
<BaseLayout>
  <section class="hero" id="top">
    <div class="hero-copy-block">
      <p class="eyebrow">Portfolio · Software / AI Engineer</p>
      <h1>Backend Python, IA générative et vision temps réel.</h1>
      <p class="hero-copy">
        Des projets concrets, documentés, avec du code lisible et des choix techniques expliqués.
        Je suis élève ingénieur en informatique, spécialisé en backend Python, IA agentique,
        computer vision et systèmes robustes. Je recherche un premier CDI de Software / AI Engineer
        à partir de septembre 2026.
      </p>
      <div class="hero-actions" aria-label="Liens principaux">
        <a class="button primary" href={links.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
        <a class="button" href={links.github} target="_blank" rel="noreferrer">GitHub</a>
        <a class="button ghost" href={links.email}>Email</a>
      </div>
      <div class="hero-stats" aria-label="Résumé profil">
        <span><strong>Disponible CDI</strong> septembre 2026</span>
        <span><strong>Stack principale</strong> Python · Cloud · GenAI</span>
        <span><strong>Paris / Île-de-France</strong> Strasbourg · ouvert France</span>
      </div>
    </div>

    <aside class="hero-panel" aria-label="Résumé recruteur">
      <div class="panel-orbit" aria-hidden="true"></div>
      <div class="availability-card">
        <span class="status-dot"></span>
        <p>Disponible pour un CDI junior Software / AI Engineer</p>
      </div>
      <div class="system-card">
        <p class="card-kicker">Focus actuel</p>
        <h2>Systèmes IA fiables, backend solide, vision temps réel.</h2>
        <div class="focus-list">
          {proofPoints.map((point) => (
            <div>
              <strong>{point.label}</strong>
              <span>{point.value}</span>
            </div>
          ))}
        </div>
      </div>
      <div class="terminal-card" aria-label="Stack technique">
        <span>$ lucas --stack</span>
        <p>Python · FastAPI · Google ADK · Vertex AI · BigQuery · Docker · OpenCV · C/C++</p>
      </div>
    </aside>
  </section>

  <section class="section proof-strip" aria-label="Arguments recruteur">
    <article>
      <span>01</span>
      <h2>Pas juste des notebooks.</h2>
      <p>Des projets avec architecture, contraintes terrain, tests, déploiement et compromis techniques.</p>
    </article>
    <article>
      <span>02</span>
      <h2>Un profil software + AI.</h2>
      <p>Backend, GenAI, computer vision, calcul parallèle et systèmes bas niveau: une approche utile pour livrer des solutions de bout en bout.</p>
    </article>
    <article>
      <span>03</span>
      <h2>Pensé pour être lu vite.</h2>
      <p>Chaque projet présente le problème, les choix techniques, les résultats et le dépôt GitHub associé.</p>
    </article>
  </section>

  <section class="section" id="projects">
    <div class="section-heading">
      <p class="eyebrow">Projets clés</p>
      <h2>Trois projets à ouvrir en premier.</h2>
      <p>
        Une sélection courte de projets orientés impact: vision temps réel, MLOps et intelligence artificielle appliquée.
      </p>
    </div>
    <div class="project-grid featured-grid">
      {featured.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <section class="section compact">
    <div class="section-heading">
      <p class="eyebrow">Autres projets techniques</p>
      <h2>D’autres projets pour montrer la profondeur technique.</h2>
    </div>
    <div class="project-grid">
      {otherProjects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <section class="section compact">
    <div class="section-heading">
      <p class="eyebrow">Labs / Work in progress</p>
      <h2>Projets en cours de consolidation ou de publication.</h2>
    </div>
    <div class="lab-grid">
      {labs.map((lab) => (
        <article class="lab-card">
          <div class="project-meta">
            <span>{lab.status}</span>
          </div>
          <h3>{lab.title}</h3>
          <p>{lab.summary}</p>
          <div class="chips" aria-label="Stack technique">
            {lab.stack.map((item) => <span>{item}</span>)}
          </div>
          <div class="project-tags">
            {lab.tags.map((tag) => <span>#{tag}</span>)}
          </div>
          {lab.repo ? (
            <a class="project-link" href={lab.repo} target="_blank" rel="noreferrer">{lab.action}</a>
          ) : (
            <span class="project-link muted">{lab.action}</span>
          )}
        </article>
      ))}
    </div>
  </section>

  <section class="section about" id="about">
    <div>
      <p class="eyebrow">About</p>
      <h2>Le positionnement en une phrase.</h2>
    </div>
    <p>
      Je cherche à rejoindre une équipe qui construit des produits techniques sérieux:
      backend Python, orchestration IA, data workflows, vision temps réel, cloud et systèmes maintenables.
    </p>
  </section>

  <section class="contact-band" id="contact" aria-label="Contact">
    <div>
      <p class="eyebrow">Contact</p>
      <h2>LinkedIn, GitHub, email. Accès direct.</h2>
    </div>
    <div class="contact-actions">
      <a class="button primary" href={links.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
      <a class="button" href={links.github} target="_blank" rel="noreferrer">GitHub</a>
      <a class="button ghost" href={links.email}>contact@lucasmarchand.dev</a>
    </div>
  </section>
</BaseLayout>
