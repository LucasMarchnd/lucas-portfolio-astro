---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const featured = projects.filter((project) => project.data.featured);
const otherProjects = projects.filter((project) => !project.data.featured);

const links = {
  linkedin: 'https://www.linkedin.com/in/lucassmarchand',
  github: 'https://github.com/LucasMarchnd',
  email: 'mailto:contact@lucasmarchand.dev',
};

const proofPoints = [
  {
    label: 'Systèmes GenAI',
    value: 'Agents, RAG, NLP-to-SQL, boucles de validation',
  },
  {
    label: 'Backend Python',
    value: 'API, tests, streaming, observabilité',
  },
  {
    label: 'Vision / Edge',
    value: 'RTSP, Jetson, monitoring, reprise sur erreur',
  },
];
---
<BaseLayout>
  <section class="hero" id="top">
    <div class="hero-copy-block">
      <p class="eyebrow">Portfolio · Software / AI Engineer</p>
      <h1>Backend, IA, vision temps réel. Des projets concrets, prêts à être lus.</h1>
      <p class="hero-copy">
        Je suis élève ingénieur en informatique, orienté backend Python, agentic AI,
        computer vision et systèmes robustes. Disponible pour un premier CDI à partir de septembre 2026.
      </p>
      <div class="hero-actions" aria-label="Liens principaux">
        <a class="button primary" href={links.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
        <a class="button" href={links.github} target="_blank" rel="noreferrer">GitHub</a>
        <a class="button ghost" href={links.email}>Email</a>
      </div>
      <div class="hero-stats" aria-label="Résumé profil">
        <span><strong>Sept. 2026</strong> disponibilité CDI</span>
        <span><strong>Python · Cloud · GenAI</strong> cœur de stack</span>
        <span><strong>Paris / Strasbourg</strong> ouvert France</span>
      </div>
    </div>

    <aside class="hero-panel" aria-label="Résumé recruteur">
      <div class="panel-orbit" aria-hidden="true"></div>
      <div class="availability-card">
        <span class="status-dot"></span>
        <p>Disponible pour un CDI junior Software / AI Engineer</p>
      </div>
      <div class="system-card">
        <p class="card-kicker">focus actuel</p>
        <h2>Orchestration IA, backend fiable, edge AI.</h2>
        <div class="signal-list">
          {proofPoints.map((point) => (
            <div>
              <strong>{point.label}</strong>
              <span>{point.value}</span>
            </div>
          ))}
        </div>
      </div>
      <div class="terminal-card" aria-label="Stack technique">
        <span>$ lucas --stack</span>
        <p>Python · FastAPI · ADK · Vertex AI · BigQuery · Docker · OpenCV · C/C++</p>
      </div>
    </aside>
  </section>

  <section class="section proof-strip" aria-label="Arguments recruteur">
    <article>
      <span>01</span>
      <h2>Pas juste des notebooks.</h2>
      <p>Des projets avec architecture, contraintes terrain, tests, déploiement et compromis techniques.</p>
    </article>
    <article>
      <span>02</span>
      <h2>Profil hybride.</h2>
      <p>Backend, GenAI, computer vision, systèmes parallèles et bas niveau: utile pour livrer de bout en bout.</p>
    </article>
    <article>
      <span>03</span>
      <h2>Lisible vite.</h2>
      <p>Chaque carte résume le signal technique et ouvre directement le dépôt GitHub correspondant.</p>
    </article>
  </section>

  <section class="section" id="projects">
    <div class="section-heading">
      <p class="eyebrow">Projets clés</p>
      <h2>Trois projets à ouvrir en premier.</h2>
      <p>
        Une sélection courte, orientée impact: agentic AI, edge video analytics,
        MLOps, reinforcement learning, HPC, compilation et engineering robuste.
      </p>
    </div>
    <div class="project-grid featured-grid">
      {featured.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <section class="section compact">
    <div class="section-heading">
      <p class="eyebrow">Autres preuves</p>
      <h2>Autres signaux techniques</h2>
    </div>
    <div class="project-grid">
      {otherProjects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <section class="section about" id="about">
    <div>
      <p class="eyebrow">About</p>
      <h2>Le positionnement en une phrase.</h2>
    </div>
    <p>
      Je cherche à rejoindre une équipe qui construit des produits techniques sérieux:
      backend Python, orchestration IA, data workflows, vision temps réel, cloud et systèmes maintenables.
    </p>
  </section>

  <section class="contact-band" id="contact" aria-label="Contact">
    <div>
      <p class="eyebrow">Contact</p>
      <h2>LinkedIn, GitHub, email. Accès direct.</h2>
    </div>
    <div class="contact-actions">
      <a class="button primary" href={links.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
      <a class="button" href={links.github} target="_blank" rel="noreferrer">GitHub</a>
      <a class="button ghost" href={links.email}>contact@lucasmarchand.dev</a>
    </div>
  </section>
</BaseLayout>
